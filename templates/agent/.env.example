# Copy to .env and edit. docker-compose auto-loads .env from this directory.

# --- Model -----------------------------------------------------------------
STRANDS_PG_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_REGION=us-east-1

# --- AWS credentials — pick ONE of the two patterns below ------------------

# Option A: named profile (laptop dev, SSO/SAML/STS-backed creds).
# Requires the ~/.aws bind mount in docker-compose.yml so boto3 can read
# your config and refresh SSO tokens into ~/.aws/sso/cache.
# Run `aws sso login --profile <name>` before `docker compose up`.
AWS_PROFILE=default

# Option B: static IAM user access key (production on a VPS/LXC without
# ~/.aws). Create a dedicated IAM user scoped narrowly to
#   bedrock:InvokeModel
# on just the model ARNs you use. No other permissions. Rotate on a
# schedule. Don't reuse across agents.
# Remove the ~/.aws mount from docker-compose.yml when you go this route —
# it'll fail to start on a host where that path doesn't exist.
#
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
