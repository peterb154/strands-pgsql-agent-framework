# Copy to .env and adjust. docker-compose auto-loads .env from this directory.
#
# Model
STRANDS_PG_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# AWS profile (must exist in ~/.aws/config and have fresh creds).
# `aws sso login --profile <name>` before `docker compose up`.
AWS_PROFILE=css-aws1
AWS_REGION=us-east-1
